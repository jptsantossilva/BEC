# Binance API
binance_api="xxx"
binance_secret="xxx"

# Kraken spot API (never enable Withdraw Funds permission)
KRAKEN_API_KEY=""
KRAKEN_API_SECRET=""

# OKX spot API. Keep withdrawal permission disabled and use an IP allowlist.
# Production and demo credentials are deliberately separate. All three values
# are required only when running the explicit read-only balance check.
OKX_API_KEY=""
OKX_API_SECRET=""
OKX_API_PASSPHRASE=""
OKX_DEMO_API_KEY=""
OKX_DEMO_API_SECRET=""
OKX_DEMO_API_PASSPHRASE=""

# SQLite web admin (required for Docker Compose; use a strong, unique password)
SQLITE_WEB_PASSWORD=""

# Telegram
telegram_chat_id="xxx"
telegram_token_closed_positions="xxx"
telegram_token_errors="xxx"
telegram_token_main="xxx"
telegram_token_signals="xxx"

# OpenAI
OPENAI_API_KEY="xxx"
BEC_OPENAI_MODEL="gpt-5.5"
